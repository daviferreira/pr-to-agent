{
  "name": "pr-to-agent",
  "version": "1.0.0",
  "description": "Chrome extension that adds a \"Send to Agent\" button to GitHub PR comments, copying the comment, diff, and PR context as a formatted prompt to your clipboard.",
  "license": "MIT",
  "author": "",
  "type": "module",
  "scripts": {
    "lint:es": "eslint .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "npm run lint:es && npm run format:check",
    "test": "npm run lint",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint",
      "prettier --check"
    ],
    "*.{json,md}": "prettier --check"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1"
  }
}
